# ---------- Database ----------
# Only needed if you want a custom password (default: postgres)
DB_PASSWORD=postgres

# ---------- Web (Next.js) ----------
SESSION_TTL_HOURS=12
# IMPORTANT: generate a real 64-char hex key for production
# openssl rand -hex 32
NODE_CREDENTIALS_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
NODE_AGENT_TIMEOUT_MS=5000
NEXT_PUBLIC_APP_NAME=HostPanel

# ---------- Seed (first run only) ----------
SEED_ADMIN_EMAIL=admin@hostpanel.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_CLIENT_PASSWORD=ClientPass123!

# ---------- Agent ----------
AGENT_API_KEY=change-me-to-a-strong-key
AGENT_DOCKER_MODE=mock
# Set to "rootless" and configure DOCKER_HOST for real containers
DOCKER_HOST=
XDG_RUNTIME_DIR=
